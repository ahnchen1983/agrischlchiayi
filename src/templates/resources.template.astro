<script is:inline src="https://d3js.org/d3.v7.min.js"></script>
<script is:inline define:vars={{ mindmapData }}>
  document.addEventListener('DOMContentLoaded', function () {
    var container = document.getElementById('resources-graph');
    if (container) {
      var data = JSON.parse(mindmapData);
      var categories = [];
      var catMap = {};
      data.nodes.forEach(function (n) {
        if (n.group === 'center') return;
        if (n.size > 10) {
          var cat = Object.assign({}, n, { children: [] });
          catMap[n.id] = cat;
          categories.push(cat);
        }
      });
      data.nodes.forEach(function (n) {
        if (n.size <= 10 && n.group !== 'center') {
          var parentId = n.id.split('_')[0];
          if (catMap[parentId]) catMap[parentId].children.push(n);
        }
      });
      var half = Math.ceil(categories.length / 2);
      var rightRoot = {
        id: 'r',
        label: '',
        children: categories.slice(0, half),
      };
      var leftRoot = { id: 'l', label: '', children: categories.slice(half) };
      var treeLayout = d3.tree().nodeSize([22, 160]);
      var rightH = d3.hierarchy(rightRoot);
      treeLayout(rightH);
      var leftH = d3.hierarchy(leftRoot);
      treeLayout(leftH);
      leftH.each(function (d) {
        d.y = -d.y;
      });
      var allNodes = [];
      var allLinks = [];
      var rootNode = {
        x: 0,
        y: 0,
        depth: 0,
        data: data.nodes.find(function (n) {
          return n.group === 'center';
        }),
        _side: 'center',
      };
      allNodes.push(rootNode);
      rightH.each(function (d) {
        if (d.depth === 0) return;
        d._side = 'right';
        allNodes.push(d);
      });
      rightH.links().forEach(function (link) {
        allLinks.push(
          link.source.depth === 0
            ? { source: rootNode, target: link.target }
            : link,
        );
      });
      leftH.each(function (d) {
        if (d.depth === 0) return;
        d._side = 'left';
        allNodes.push(d);
      });
      leftH.links().forEach(function (link) {
        allLinks.push(
          link.source.depth === 0
            ? { source: rootNode, target: link.target }
            : link,
        );
      });
      var x0 = -100,
        x1 = 100,
        y0 = -500,
        y1 = 500;
      allNodes.forEach(function (d) {
        var nx = d.x || 0,
          ny = d.y || 0;
        if (nx < x0) x0 = nx;
        if (nx > x1) x1 = nx;
        if (ny < y0) y0 = ny;
        if (ny > y1) y1 = ny;
      });
      var width = container.clientWidth;
      var padding = 120;
      var svgH = Math.max(700, x1 - x0 + padding * 2);
      var centerX = width / 2;
      var centerY = svgH / 2;
      var svg = d3
        .select('#resources-graph')
        .append('svg')
        .attr('width', width)
        .attr('height', svgH);
      var g = svg
        .append('g')
        .attr('transform', 'translate(' + centerX + ',' + centerY + ')');
      svg
        .call(
          d3
            .zoom()
            .scaleExtent([0.3, 2.5])
            .on('zoom', function (event) {
              g.attr('transform', event.transform);
            }),
        )
        .call(
          d3.zoom().transform,
          d3.zoomIdentity.translate(centerX, centerY).scale(0.9),
        );
      g.append('g')
        .attr('fill', 'none')
        .selectAll('path')
        .data(allLinks)
        .join('path')
        .attr('d', function (d) {
          var sy = d.source.y || 0,
            sx = d.source.x || 0,
            ty = d.target.y || 0,
            tx = d.target.x || 0,
            my = (sy + ty) / 2;
          return (
            'M' +
            sy +
            ',' +
            sx +
            ' C' +
            my +
            ',' +
            sx +
            ' ' +
            my +
            ',' +
            tx +
            ' ' +
            ty +
            ',' +
            tx
          );
        })
        .attr('stroke', function (d) {
          return d.target.data.color || '#94a3b8';
        })
        .attr('stroke-width', function (d) {
          return (d.target.depth || 0) <= 1 ? 2 : 1.2;
        })
        .attr('stroke-opacity', 0.5);
      var nodeG = g
        .append('g')
        .selectAll('g')
        .data(allNodes)
        .join('g')
        .attr('transform', function (d) {
          return 'translate(' + (d.y || 0) + ',' + (d.x || 0) + ')';
        })
        .attr('cursor', function (d) {
          return d.data.url ? 'pointer' : 'default';
        });
      nodeG
        .append('circle')
        .attr('r', function (d) {
          if ((d.depth || 0) === 0) return 10;
          if ((d.depth || 0) === 1) return 6;
          return 3.5;
        })
        .attr('fill', function (d) {
          return d.data.color || '#94a3b8';
        })
        .attr('stroke', '#fff')
        .attr('stroke-width', 1.5);
      nodeG
        .append('text')
        .attr('dy', '0.32em')
        .attr('x', function (d) {
          if ((d.depth || 0) === 0) return 0;
          if (d._side === 'left') return d.children ? 10 : -8;
          return d.children ? -10 : 8;
        })
        .attr('text-anchor', function (d) {
          if ((d.depth || 0) === 0) return 'middle';
          if (d._side === 'left') return d.children ? 'start' : 'end';
          return d.children ? 'end' : 'start';
        })
        .attr('font-size', function (d) {
          if ((d.depth || 0) === 0) return '14px';
          if ((d.depth || 0) === 1) return '12px';
          return '10px';
        })
        .attr('font-weight', function (d) {
          return (d.depth || 0) <= 1 ? '700' : '400';
        })
        .attr('fill', function (d) {
          if ((d.depth || 0) === 0) return '#065f46';
          if ((d.depth || 0) === 1) return '#1a1a1a';
          return '#555';
        })
        .text(function (d) {
          return d.data.label || d.data.name || '';
        });
      nodeG.on('click', function (event, d) {
        if (d.data.url)
          window.open(d.data.url, '_blank', 'noopener noreferrer');
      });
      nodeG
        .on('mouseover', function () {
          d3.select(this)
            .select('circle')
            .transition()
            .duration(150)
            .attr('stroke', '#059669')
            .attr('stroke-width', 3);
          d3.select(this)
            .select('text')
            .transition()
            .duration(150)
            .attr('fill', '#065f46')
            .attr('font-weight', '700');
        })
        .on('mouseout', function (event, d) {
          d3.select(this)
            .select('circle')
            .transition()
            .duration(150)
            .attr('stroke', '#fff')
            .attr('stroke-width', 1.5);
          d3.select(this)
            .select('text')
            .transition()
            .duration(150)
            .attr(
              'fill',
              (d.depth || 0) === 0
                ? '#065f46'
                : (d.depth || 0) === 1
                  ? '#1a1a1a'
                  : '#555',
            )
            .attr('font-weight', (d.depth || 0) <= 1 ? '700' : '400');
        });
    }
    document.querySelectorAll('.site-favicon').forEach(function (img) {
      img.addEventListener('error', function () {
        this.onerror = null;
        this.src =
          "data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🌐</text></svg>";
      });
    });
    var nav = document.getElementById('chapter-nav');
    if (nav) {
      var header = document.querySelector('header');
      if (header) {
        nav.style.top = header.getBoundingClientRect().height + 'px';
      }
    }
    var chapterSections = document.querySelectorAll('.chapter-section');
    var chapterLinks = document.querySelectorAll('.chapter-link');
    if (chapterSections.length > 0 && chapterLinks.length > 0) {
      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting) {
              var id = entry.target.id;
              chapterLinks.forEach(function (link) {
                link.classList.toggle(
                  'active',
                  link.getAttribute('data-chapter') === id,
                );
              });
            }
          });
        },
        { rootMargin: '-20% 0px -60% 0px', threshold: 0 },
      );
      chapterSections.forEach(function (section) {
        observer.observe(section);
      });
    }
    var searchInput = document.getElementById('resources-search');
    if (searchInput) {
      searchInput.addEventListener('input', function () {
        var query = this.value.toLowerCase().trim();
        document.querySelectorAll('.site-card').forEach(function (card) {
          var searchData = (
            card.getAttribute('data-search') || ''
          ).toLowerCase();
          if (!query || searchData.indexOf(query) !== -1) {
            card.classList.remove('hidden');
          } else {
            card.classList.add('hidden');
          }
        });
        document.querySelectorAll('.subcategory').forEach(function (sub) {
          sub.classList.toggle(
            'all-hidden',
            sub.querySelectorAll('.site-card:not(.hidden)').length === 0,
          );
        });
      });
    }
  });
</script>
