---
import Layout from '../layouts/Layout.astro';
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from '../i18n/utils';
import type { ResourceSite } from '../data/resources-data';
import {
  heroCategories,
  agriGovernanceCentral,
  agriGovernanceLocal,
  agriGovernancePolicy,
  agriTechResearch,
  agriTechInnovation,
  agriTechExtension,
  agriMarketingOnline,
  agriMarketingDirect,
  agriMarketingCertification,
  agriFinanceChannels,
  agriFinanceSubsidy,
  agriFinanceInsurance,
  agriSustainabilityWater,
  agriSustainabilityOrganic,
  agriSustainabilityClimate,
} from '../data/resources-data';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const toHref = (path: string) => base + translatePath(path);

const chapters = [
  {
    id: 'agri-governance',
    navKey: 'resources.nav.agriGovernance' as const,
    titleKey: 'resources.chapter.agri.governance.title' as const,
    storyKey: 'resources.chapter.agri.governance.story' as const,
    curatorKey: 'resources.curator.agri.governance' as const,
    featured: [...agriGovernanceCentral, ...agriGovernanceLocal, ...agriGovernancePolicy].filter((s) => s.featured),
    insights: [
      { numKey: 'resources.insight.agri.ministries.number' as const, labelKey: 'resources.insight.agri.ministries.label' as const },
      { numKey: 'resources.insight.agri.changefarms.number' as const, labelKey: 'resources.insight.agri.changefarms.label' as const },
      { numKey: 'resources.insight.agri.research.number' as const, labelKey: 'resources.insight.agri.research.label' as const },
    ],
    subcategories: [
      { titleKey: 'resources.section.agriCentral' as const, descKey: 'resources.section.agriCentral.desc' as const, sites: agriGovernanceCentral },
      { titleKey: 'resources.section.agriLocal' as const, descKey: 'resources.section.agriLocal.desc' as const, sites: agriGovernanceLocal },
      { titleKey: 'resources.section.agriPolicy' as const, descKey: 'resources.section.agriPolicy.desc' as const, sites: agriGovernancePolicy },
    ],
    relatedKeys: ['resources.related.agri.governance.1' as const, 'resources.related.agri.governance.2' as const, 'resources.related.agri.governance.3' as const],
    relatedPaths: ['/crops/果樹類別與栽培/', '/crops/蔬菜類別與栽培/', '/crops/水稻類別與栽培/'],
  },
  {
    id: 'agri-technology',
    navKey: 'resources.nav.agriTechnology' as const,
    titleKey: 'resources.chapter.agri.technology.title' as const,
    storyKey: 'resources.chapter.agri.technology.story' as const,
    curatorKey: 'resources.curator.agri.technology' as const,
    featured: [...agriTechResearch, ...agriTechInnovation, ...agriTechExtension].filter((s) => s.featured),
    insights: [
      { numKey: 'resources.insight.agri.research.number' as const, labelKey: 'resources.insight.agri.research.label' as const },
      { numKey: 'resources.insight.agri.changefarms.number' as const, labelKey: 'resources.insight.agri.changefarms.label' as const },
      { numKey: 'resources.insight.agri.ministries.number' as const, labelKey: 'resources.insight.agri.ministries.label' as const },
    ],
    subcategories: [
      { titleKey: 'resources.section.agriResearch' as const, descKey: 'resources.section.agriResearch.desc' as const, sites: agriTechResearch },
      { titleKey: 'resources.section.agriInnovation' as const, descKey: 'resources.section.agriInnovation.desc' as const, sites: agriTechInnovation },
      { titleKey: 'resources.section.agriExtension' as const, descKey: 'resources.section.agriExtension.desc' as const, sites: agriTechExtension },
    ],
    relatedKeys: ['resources.related.agri.technology.1' as const, 'resources.related.agri.technology.2' as const, 'resources.related.agri.technology.3' as const],
    relatedPaths: ['/techniques/有機農業/', '/techniques/精準農業/', '/techniques/友善農業/'],
  },
  {
    id: 'agri-marketing',
    navKey: 'resources.nav.agriMarketing' as const,
    titleKey: 'resources.chapter.agri.marketing.title' as const,
    storyKey: 'resources.chapter.agri.marketing.story' as const,
    curatorKey: 'resources.curator.agri.marketing' as const,
    featured: [...agriMarketingOnline, ...agriMarketingDirect, ...agriMarketingCertification].filter((s) => s.featured),
    insights: [
      { numKey: 'resources.insight.agri.ministries.number' as const, labelKey: 'resources.insight.agri.ministries.label' as const },
      { numKey: 'resources.insight.agri.changefarms.number' as const, labelKey: 'resources.insight.agri.changefarms.label' as const },
      { numKey: 'resources.insight.agri.research.number' as const, labelKey: 'resources.insight.agri.research.label' as const },
    ],
    subcategories: [
      { titleKey: 'resources.section.agriOnline' as const, descKey: 'resources.section.agriOnline.desc' as const, sites: agriMarketingOnline },
      { titleKey: 'resources.section.agriDirect' as const, descKey: 'resources.section.agriDirect.desc' as const, sites: agriMarketingDirect },
      { titleKey: 'resources.section.agriCertification' as const, descKey: 'resources.section.agriCertification.desc' as const, sites: agriMarketingCertification },
    ],
    relatedKeys: ['resources.related.agri.marketing.1' as const, 'resources.related.agri.marketing.2' as const, 'resources.related.agri.marketing.3' as const],
    relatedPaths: ['/marketing/農產品銷售通路/', '/marketing/農民市集與直銷/', '/marketing/有機認證與品牌/'],
  },
  {
    id: 'agri-finance',
    navKey: 'resources.nav.agriFinance' as const,
    titleKey: 'resources.chapter.agri.finance.title' as const,
    storyKey: 'resources.chapter.agri.finance.story' as const,
    curatorKey: 'resources.curator.agri.finance' as const,
    featured: [...agriFinanceChannels, ...agriFinanceSubsidy, ...agriFinanceInsurance].filter((s) => s.featured),
    insights: [
      { numKey: 'resources.insight.agri.ministries.number' as const, labelKey: 'resources.insight.agri.ministries.label' as const },
      { numKey: 'resources.insight.agri.changefarms.number' as const, labelKey: 'resources.insight.agri.changefarms.label' as const },
      { numKey: 'resources.insight.agri.research.number' as const, labelKey: 'resources.insight.agri.research.label' as const },
    ],
    subcategories: [
      { titleKey: 'resources.section.agriLending' as const, descKey: 'resources.section.agriLending.desc' as const, sites: agriFinanceChannels },
      { titleKey: 'resources.section.agriSubsidy' as const, descKey: 'resources.section.agriSubsidy.desc' as const, sites: agriFinanceSubsidy },
      { titleKey: 'resources.section.agriInsurance' as const, descKey: 'resources.section.agriInsurance.desc' as const, sites: agriFinanceInsurance },
    ],
    relatedKeys: ['resources.related.agri.finance.1' as const, 'resources.related.agri.finance.2' as const, 'resources.related.agri.finance.3' as const],
    relatedPaths: ['/support/農業融資與補助/', '/support/農業保險/', '/support/農業合作社/'],
  },
  {
    id: 'agri-sustainability',
    navKey: 'resources.nav.agriSustainability' as const,
    titleKey: 'resources.chapter.agri.sustainability.title' as const,
    storyKey: 'resources.chapter.agri.sustainability.story' as const,
    curatorKey: 'resources.curator.agri.sustainability' as const,
    featured: [...agriSustainabilityWater, ...agriSustainabilityOrganic, ...agriSustainabilityClimate].filter((s) => s.featured),
    insights: [
      { numKey: 'resources.insight.agri.ministries.number' as const, labelKey: 'resources.insight.agri.ministries.label' as const },
      { numKey: 'resources.insight.agri.changefarms.number' as const, labelKey: 'resources.insight.agri.changefarms.label' as const },
      { numKey: 'resources.insight.agri.research.number' as const, labelKey: 'resources.insight.agri.research.label' as const },
    ],
    subcategories: [
      { titleKey: 'resources.section.agriWater' as const, descKey: 'resources.section.agriWater.desc' as const, sites: agriSustainabilityWater },
      { titleKey: 'resources.section.agriOrganic' as const, descKey: 'resources.section.agriOrganic.desc' as const, sites: agriSustainabilityOrganic },
      { titleKey: 'resources.section.agriClimate' as const, descKey: 'resources.section.agriClimate.desc' as const, sites: agriSustainabilityClimate },
    ],
    relatedKeys: ['resources.related.agri.sustainability.1' as const, 'resources.related.agri.sustainability.2' as const, 'resources.related.agri.sustainability.3' as const],
    relatedPaths: ['/sustainability/水資源與灌溉/', '/sustainability/友善農業/', '/sustainability/氣候調適/'],
  },
];

const allSites = [
  ...agriGovernanceCentral,
  ...agriGovernanceLocal,
  ...agriGovernancePolicy,
  ...agriTechResearch,
  ...agriTechInnovation,
  ...agriTechExtension,
  ...agriMarketingOnline,
  ...agriMarketingDirect,
  ...agriMarketingCertification,
  ...agriFinanceChannels,
  ...agriFinanceSubsidy,
  ...agriFinanceInsurance,
  ...agriSustainabilityWater,
  ...agriSustainabilityOrganic,
  ...agriSustainabilityClimate,
];
const totalCount = allSites.length;

type MindMapNode = {
  id: string;
  label: string;
  group: string;
  size: number;
  color: string;
  url?: string;
};
const mindmapNodes: MindMapNode[] = [
  {
    id: 'taiwan',
    label: t('resources.mindmap.root.label'),
    group: 'center',
    size: 26,
    color: '#065f46',
  },
];
const mindmapEdges: { source: string; target: string }[] = [];

heroCategories.forEach((category) => {
  mindmapNodes.push({
    id: category.id,
    label: t(category.labelKey as any),
    group: category.id,
    size: 16,
    color: category.color,
  });
  mindmapEdges.push({ source: 'taiwan', target: category.id });
  category.sites.forEach((site, index) => {
    const nodeId = `${category.id}_${index}`;
    mindmapNodes.push({
      id: nodeId,
      label: t(site.nameKey as any),
      group: category.id,
      size: 8,
      color: category.color,
      url: site.url,
    });
    mindmapEdges.push({ source: category.id, target: nodeId });
  });
});

const mindmapData = JSON.stringify({
  nodes: mindmapNodes,
  edges: mindmapEdges,
});
---

<Layout
  title={t('resources.meta.title')}
  description={t('resources.meta.description')}
  lang={lang}
>
  <main class="resources-page">
    <div class="container">
      <section class="hero">
        <div class="hero-content">
          <h1 class="hero-title">{t('resources.hero.title')}</h1>
          <p
            class="hero-subtitle"
            set:html={t('resources.hero.subtitle.html')}
          />
        </div>
        <!-- Mindmap hidden for now
        <div class="resources-mindmap">
          <div id="resources-graph"></div>
        </div>
        -->
      </section>

      <!-- breadcrumb removed -->

      <div class="reading-guide">
        <h2 class="reading-guide-title">{t('resources.guide.title')}</h2>
        <p class="reading-guide-desc">{t('resources.guide.desc')}</p>
      </div>

      <nav class="chapter-nav" id="chapter-nav">
        <div class="chapter-nav-inner">
          {
            chapters.map((ch) => (
              <a href={`#${ch.id}`} class="chapter-link" data-chapter={ch.id}>
                {t(ch.navKey)}
              </a>
            ))
          }
          <div class="chapter-search">
            <input
              type="text"
              id="resources-search"
              placeholder={t('resources.search.placeholder')}
              class="search-input"
            />
          </div>
        </div>
      </nav>

      {
        chapters.map((chapter) => (
          <section class="chapter-section" id={chapter.id}>
            <h2 class="chapter-title NotoSerif">{t(chapter.titleKey)}</h2>
            <p class="story-text">{t(chapter.storyKey)}</p>
            <div class="curator-note">
              <p>{t(chapter.curatorKey)}</p>
            </div>

            {chapter.featured.length > 0 && (
              <div class="featured-section">
                <div class="featured-grid">
                  {chapter.featured.slice(0, 3).map((site: ResourceSite) => (
                    <a
                      href={site.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="featured-card site-card"
                      data-search={`${t(site.nameKey as any)} ${site.domain}`}
                    >
                      <div class="featured-star">&#11088;</div>
                      <img
                        src={`https://www.google.com/s2/favicons?domain=${site.domain}&sz=32`}
                        alt=""
                        class="site-favicon"
                        loading="lazy"
                      />
                      <div class="site-info">
                        <div class="site-name">{t(site.nameKey as any)}</div>
                        <div class="site-domain">{site.domain}</div>
                        {site.descKey && (
                          <div class="featured-desc">
                            {t(site.descKey as any)}
                          </div>
                        )}
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            )}

            <div class="insight-cards">
              {chapter.insights.map((ins) => (
                <div class="insight-card">
                  <div class="insight-number">{t(ins.numKey)}</div>
                  <div class="insight-label">{t(ins.labelKey)}</div>
                </div>
              ))}
            </div>

            {chapter.subcategories.map((sub) => (
              <div class="subcategory">
                <h3 class="subcategory-title">{t(sub.titleKey)}</h3>
                {sub.descKey && (
                  <p class="subcategory-desc">{t(sub.descKey as any)}</p>
                )}
                <div class="site-grid">
                  {sub.sites.map((site: ResourceSite) => (
                    <a
                      href={site.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="site-card"
                      data-search={`${t(site.nameKey as any)} ${site.domain}`}
                    >
                      <img
                        src={`https://www.google.com/s2/favicons?domain=${site.domain}&sz=32`}
                        alt=""
                        class="site-favicon"
                        loading="lazy"
                      />
                      <div class="site-info">
                        <div class="site-name">{t(site.nameKey as any)}</div>
                        <div class="site-domain">{site.domain}</div>
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            ))}

            <div class="related-articles">
              <span class="related-label">{t('resources.related.label')}:</span>
              {chapter.relatedKeys.map((key, i) => (
                <Fragment>
                  <a
                    href={toHref(chapter.relatedPaths?.[i] || '/')}
                    class="related-link"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    {t(key)}
                  </a>
                  {i < chapter.relatedKeys.length - 1 ? ' · ' : ''}
                </Fragment>
              ))}
            </div>

            <div class="section-footer">
              <span>📅 {t('resources.section.footer.verified')}</span>
              <span class="report-link-separator">｜</span>
              <a
                href="https://github.com/ahnchen1983/agrischlchiayi/issues"
                target="_blank"
                rel="noopener noreferrer"
                class="report-link"
              >
                🔗 {t('resources.section.footer.reportLink')}
              </a>
            </div>
          </section>
        ))
      }

      <div class="footer-stats">
        <div class="stat-item">
          <span class="stat-number">{totalCount}+</span><span class="stat-label"
            >{t('resources.stats.collected')}</span
          >
        </div>
        <div class="stat-item">
          <span class="stat-number">5</span><span class="stat-label"
            >{t('resources.stats.chapters')}</span
          >
        </div>
        <div class="stat-item">
          <span class="stat-number">15+</span><span class="stat-label"
            >{t('resources.stats.subcategories')}</span
          >
        </div>
      </div>

      <div class="back-to-home">
        <a href={toHref('/')} class="btn-primary">{t('resources.backToHome')}</a
        >
      </div>
    </div>
  </main>
</Layout>

<style>
  .resources-page {
    min-height: 100vh;
    background: #ffffff;
    font-family: 'jf-jinxuanlatte', 'Noto Sans TC', sans-serif;
  }
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem;
  }
  .hero {
    text-align: center;
    margin-bottom: 3rem;
    padding: 4rem 0;
  }
  .hero-title {
    font-size: 3.5rem;
    font-weight: 900;
    background: linear-gradient(135deg, #065f46, #059669, #10b981);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .hero-subtitle {
    font-size: 1.3rem;
    color: #64748b;
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto;
  }
  .resources-mindmap {
    margin-top: 3rem;
    padding: 2rem;
    background: #fafffe;
    border-radius: 16px;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }
  #resources-graph {
    overflow: visible;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    height: auto;
    min-height: 700px;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(10px);
    position: relative;
    overflow: hidden;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 2rem;
    font-size: 0.95rem;
    color: #64748b;
  }
  .breadcrumb a {
    color: #059669;
    text-decoration: none;
    border-bottom: none !important;
    padding-bottom: 0 !important;
    transition: color 0.2s ease;
  }
  .breadcrumb a:hover {
    color: #065f46;
  }
  .separator {
    color: #94a3b8;
  }
  .current {
    font-weight: 600;
    color: #374151;
  }
  .reading-guide {
    background: #ecfdf5;
    border: 1px solid #d1fae5;
    border-radius: 12px;
    padding: 1.5rem 2rem;
    margin-bottom: 2rem;
  }
  .reading-guide-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: #065f46;
    margin-bottom: 0.5rem;
  }
  .reading-guide-desc {
    font-size: 0.95rem;
    color: #047857;
    line-height: 1.6;
    margin: 0;
  }
  .chapter-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #ecfdf5;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
    padding: 0.75rem 0;
    box-shadow: 0 2px 8px -2px rgba(0, 0, 0, 0.1);
    transition: top 0.3s ease;
  }
  .chapter-nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0 2rem;
  }
  .chapter-link {
    flex: 1;
    text-align: center;
    padding: 0.5rem 0.75rem;
    color: #065f46;
    text-decoration: none !important;
    font-weight: 600;
    font-size: 0.95rem;
    border-radius: 8px;
    transition: all 0.2s ease;
    border-bottom: none !important;
    padding-bottom: 0.5rem !important;
    white-space: nowrap;
  }
  .chapter-link:hover {
    background: #d1fae5;
    color: #065f46;
  }
  .chapter-link.active,
  .chapter-link.active:hover,
  .chapter-link.active:visited {
    background: #065f46 !important;
    color: #ffffff !important;
  }
  .chapter-search {
    flex: 0 0 auto;
    margin-left: 1rem;
  }
  .search-input {
    padding: 0.5rem 1rem;
    border: 1px solid #d1fae5;
    border-radius: 8px;
    font-size: 0.9rem;
    background: #ffffff;
    color: #374151;
    width: 200px;
    outline: none;
    transition: border-color 0.2s ease;
  }
  .search-input:focus {
    border-color: #059669;
    box-shadow: 0 0 0 2px rgba(5, 150, 105, 0.15);
  }
  .chapter-section {
    margin-bottom: 5rem;
    padding-top: 5rem;
  }
  .chapter-title {
    font-size: 2.5rem;
    font-weight: 800;
    color: #065f46;
    margin-bottom: 1rem;
  }
  .story-text {
    font-size: 1.15rem;
    color: #475569;
    line-height: 1.8;
    margin-bottom: 1.5rem;
    max-width: 800px;
  }
  .curator-note {
    background: #f0fdf4;
    border-left: 4px solid #059669;
    padding: 1.25rem 1.5rem;
    margin-bottom: 2rem;
    border-radius: 0 8px 8px 0;
  }
  .curator-note p {
    font-size: 0.95rem;
    color: #374151;
    line-height: 1.7;
    margin: 0;
  }
  .featured-section {
    margin-bottom: 2.5rem;
  }
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .featured-card {
    position: relative;
    padding: 0.625rem 1rem !important;
    background: #f0fdf4 !important;
    border: 1px solid #d1fae5 !important;
    border-left: 4px solid #059669 !important;
    border-radius: 12px;
    min-height: auto;
    flex-direction: row;
    box-shadow: 0 2px 8px -2px rgba(5, 150, 105, 0.12);
  }
  .featured-card:hover {
    border-color: #059669 !important;
    transform: translateY(-2px);
    box-shadow: 0 8px 25px -5px rgba(0, 0, 0, 0.1);
  }
  .featured-card .site-name {
    color: #059669;
  }
  .featured-star {
    display: none;
  }
  .featured-desc {
    font-size: 0.85rem;
    color: #475569;
    line-height: 1.5;
    margin-top: 0.5rem;
  }
  .insight-cards {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }
  .insight-card {
    flex: 1;
    text-align: center;
    padding: 1.25rem;
    background: #ffffff;
    border: 1px solid #d1fae5;
    border-radius: 12px;
  }
  .insight-number {
    font-size: 2rem;
    font-weight: 800;
    color: #059669;
    margin-bottom: 0.25rem;
  }
  .insight-label {
    font-size: 0.9rem;
    color: #64748b;
    font-weight: 500;
  }
  .subcategory {
    margin-bottom: 2.5rem;
  }
  .subcategory-title {
    font-size: 1.25rem;
    color: #065f46;
    margin-bottom: 0.5rem;
    padding-left: 0.75rem;
    border-left: 4px solid #10b981;
    font-weight: 700;
  }
  .subcategory-desc {
    font-size: 0.95rem;
    color: #475569;
    line-height: 1.6;
    margin: 0 0 1.25rem 0.75rem;
    padding-left: 0.75rem;
  }
