---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import CoverStory from '../components/home/CoverStory.astro';
import RandomDiscovery from '../components/home/RandomDiscovery.astro';
import ReadingPath from '../components/ReadingPath.astro';
import FeatureCards from '../components/FeatureCards.astro';
import CategoriesSection from '../components/home/CategoriesSection.astro';
import RecentUpdates from '../components/home/RecentUpdates.astro';
import ContributeSection from '../components/home/ContributeSection.astro';
import { fetchRecentCommits } from '../lib/commits';

const recentCommits = await fetchRecentCommits();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const readingPathSteps = [
  {
    href: `${base}/agri-basics/土壤基礎知識`,
    title: '🌱 土壤基礎知識',
    description: '認識嘉義地區土壤特性，小農經營的第一課',
    time: '5 min',
  },
  {
    href: `${base}/crop-production/小番茄栽培技術`,
    title: '🌿 小番茄栽培技術',
    description: '嘉義招牌作物：從選種到採收的完整指南',
    time: '6 min',
  },
  {
    href: `${base}/farm-management/農場財務健檢與規劃`,
    title: '🏡 農場財務健檢與規劃',
    description: '掌握成本結構、規劃融資——經營農場的必修課',
    time: '5 min',
  },
  {
    href: `${base}/crop-production/農作物病徵診斷指南`,
    title: '🔍 農作物病徵診斷指南',
    description: '用對眼光看植物——早期發現、早期防控',
    time: '6 min',
  },
  {
    href: `${base}/smart-farming/智慧農業基礎設施建設指南`,
    title: '🤖 智慧農業基礎設施建設',
    description: '從水電實務到自動灌溉——科技改變農田',
    time: '5 min',
  },
  {
    href: `${base}/agri-marketing/農民市集與直銷模式實務`,
    title: '📦 農民市集與直銷模式實務',
    description: '產品怎樣賣得更好？直銷、通路、電商全策略',
    time: '6 min',
  },
  {
    href: `${base}/grants-planning/農業補助申請指南`,
    title: '💰 農業補助申請指南',
    description: '政府資源怎麼申請？補助計畫撰寫實務',
    time: '4 min',
  },
];

const readingPathFooterItems = [
  { icon: '⏱️', label: '總計 37 分鐘' },
  { icon: '🎯', label: '跨越 8 大領域' },
  { icon: '🌟', label: '從入門到經營實務' },
];
---

<Layout
  title="嘉義國本學堂 — 開源農業知識平台"
  description="嘉義縣國本學堂課程精華，涵蓋農業基礎、作物生產、智慧農業等 10 大主題，互動知識圖譜、開放社群協作。"
>
  <HeroSection />

  <CoverStory />

  <RandomDiscovery />

  <ReadingPath
    title="📖 從零開始，37 分鐘快速入門"
    subtitle="7 篇精選文章：從基礎到實務，解決嘉義農場的三大挑戰"
    steps={readingPathSteps}
    footerItems={readingPathFooterItems}
    continueHref="#categories"
    continueLabel="深入瞭解三大挑戰的完整解決方案 →"
  />

  <FeatureCards
    lang="zh-TW"
    sectionTitle="為什麼需要嘉義國本學堂？"
    cards={[
      {
        icon: '🎯',
        title: '51 篇實務指南',
        description: '從嘉義農民的真實挑戰出發，涵蓋生產、財務、銷售全流程',
      },
      {
        icon: '🕸️',
        title: '互動知識圖譜',
        description: '用 D3.js 視覺化農業知識間的關聯與脈絡',
      },
      {
        icon: '🌾',
        title: '最新實務內容',
        description: '新增農場財務、植物診斷、鳳梨機械化等高價值指南',
      },
      {
        icon: '📖',
        title: '開源共創社群',
        description: '貢獻新農友案例、實務經驗，讓知識持續進化',
      },
    ]}
  >
    <div class="features-cta">
      <a href={`${base}/graph`} class="feature-btn">🔗 知識圖譜 — 探索文章之間的連結</a>
      <a
        href="https://github.com/ahnchen1983/agrischlchiayi/tree/main/knowledge"
        target="_blank"
        rel="noopener noreferrer"
        class="feature-btn secondary">📂 瀏覽原始資料 ↗</a
      >
    </div>
  </FeatureCards>

  <section class="mini-graph-section">
    <a href={`${base}/graph`} class="mini-graph-link">
      <div class="mini-graph-text">
        <h3>🕸️ 知識圖譜</h3>
        <p>每篇文章都不是孤島——點擊探索農業知識的連結網絡</p>
      </div>
      <div id="mini-graph" class="mini-graph-container"></div>
    </a>
  </section>

  <CategoriesSection>
    <Fragment slot="prose">
      <h2 style="text-align: center; margin-bottom: 2rem; color: #1f2937; font-size: 1.8rem;">嘉義農場的三大挑戰</h2>

      <p style="font-weight: 600; color: #2d5016; font-size: 1.1rem; margin-bottom: 1rem;">
        ✓ 挑戰 1：「怎樣提高產量與品質？」
      </p>
      <p>
        從<a href={`${base}/agri-basics`} class="topic-pill">🌱 土壤基礎知識</a>開始，
        掌握嘉義地區的栽培祕訣。具體作物方面，
        <a href={`${base}/crop-production/小番茄栽培技術`} class="topic-pill">🌿 小番茄栽培</a>、
        <a href={`${base}/crop-production/鳳梨栽培與機械化指南`} class="topic-pill">🍍 鳳梨栽培與機械化</a>等指南
        涵蓋選種、肥培、病蟲害管理全過程。
        而<a href={`${base}/crop-production/農作物病徵診斷指南`} class="topic-pill">🔍 農作物病徵診斷指南</a>
        讓你用對眼光看植物，早期發現風險。
      </p>

      <p style="font-weight: 600; color: #2d5016; font-size: 1.1rem; margin-bottom: 1rem; margin-top: 1.5rem;">
        ✓ 挑戰 2：「成本太高，怎麼降本增效？」
      </p>
      <p>
        <a href={`${base}/farm-management/農場財務健檢與規劃`} class="topic-pill">🏡 農場財務健檢與規劃</a>
        幫你讀懂成本結構、進行財務規劃——小農不能只靠直覺經營。
        <a href={`${base}/smart-farming/智慧農業基礎設施建設指南`} class="topic-pill">🤖 智慧農業基礎設施建設</a>
        結合水電實務與自動灌溉，降低人力與資源成本。
        <a href={`${base}/facility-farming`} class="topic-pill">🏗️ 設施農業</a>
        讓溫室環控與精準灌溉成為現實，提升每平方公尺的產值。
      </p>

      <p style="font-weight: 600; color: #2d5016; font-size: 1.1rem; margin-bottom: 1rem; margin-top: 1.5rem;">
        ✓ 挑戰 3：「產品怎樣賣得更好？」
      </p>
      <p>
        <a href={`${base}/agri-marketing/農民市集與直銷模式實務`} class="topic-pill">📦 農民市集與直銷模式實務</a>、
        <a href={`${base}/agri-marketing/小黃瓜銷售通路策略`} class="topic-pill">通路策略</a>、
        <a href={`${base}/agri-marketing/農業品牌建立與精品化策略`} class="topic-pill">品牌建立與精品化</a>——
        嘉義新一代農友不只種得好，更懂得經營銷售。
        <a href={`${base}/agri-marketing/外銷認證與國際市場開拓`} class="topic-pill">外銷認證與國際市場</a>
        更是拓展收入的新機會。
      </p>

      <p style="margin-top: 2rem; padding-top: 1.5rem; border-top: 2px solid #e5e7eb;">
        國本學堂將 50+ 年課程經驗系統化為 51 篇實務指南，
        涵蓋<a href={`${base}/agri-advanced`} class="topic-pill">🌾 多元農業經營</a>、
        <a href={`${base}/grants-planning`} class="topic-pill">💰 補助申請</a>，
        以及透過<a href={`${base}/field-visits`} class="topic-pill">🚜 場域交流觀摩</a>
        走訪模範農場。所有知識都從嘉義的真實農場出發，等你探索。
      </p>
    </Fragment>
  </CategoriesSection>

  <RecentUpdates commits={recentCommits} />

  <ContributeSection />
</Layout>

<script is:inline src="https://d3js.org/d3.v7.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    const container = document.getElementById('mini-graph');
    if (container) {
      const categories = [
        { id: 'agri-basics', name: '農業基礎', color: '#22c55e' },
        { id: 'agri-advanced', name: '進階實務', color: '#16a34a' },
        { id: 'farm-management', name: '農場經營', color: '#ca8a04' },
        { id: 'crop-production', name: '作物生產', color: '#15803d' },
        { id: 'facility-farming', name: '設施農業', color: '#0891b2' },
        { id: 'smart-farming', name: '智慧農業', color: '#2563eb' },
        { id: 'agri-marketing', name: '農產銷售', color: '#ea580c' },
        { id: 'grants-planning', name: '計畫補助', color: '#7c3aed' },
        { id: 'field-visits', name: '場域觀摩', color: '#b45309' },
        { id: 'livestock-health', name: '畜牧健康', color: '#dc2626' },
      ];

      const nodes = [
        {
          id: 'chiayi-agri',
          name: '嘉義國本學堂',
          size: 18,
          color: '#2d5016',
          group: 'core',
        },
        ...categories.map((c) => ({
          id: c.id,
          name: c.name,
          size: 12,
          color: c.color,
          group: 'category',
        })),
      ];

      const edges = categories.map((c) => ({ source: 'chiayi-agri', target: c.id }));
      const crossLinks = [
        ['agri-basics', 'agri-advanced'],
        ['agri-basics', 'crop-production'],
        ['farm-management', 'agri-marketing'],
        ['farm-management', 'grants-planning'],
        ['crop-production', 'facility-farming'],
        ['smart-farming', 'facility-farming'],
        ['agri-marketing', 'field-visits'],
        ['livestock-health', 'agri-advanced'],
        ['grants-planning', 'field-visits'],
        ['smart-farming', 'crop-production'],
      ];
      crossLinks.forEach(([source, target]) => edges.push({ source, target }));

      const width = container.clientWidth;
      const height = 300;

      const svg = d3
        .select('#mini-graph')
        .append('svg')
        .attr('viewBox', `0 0 ${width} ${height}`)
        .attr('preserveAspectRatio', 'xMidYMid meet');

      const simulation = d3
        .forceSimulation(nodes)
        .force(
          'link',
          d3
            .forceLink(edges)
            .id((d) => d.id)
            .distance(60),
        )
        .force('charge', d3.forceManyBody().strength(-120))
        .force('center', d3.forceCenter(width / 2, height / 2))
        .force(
          'collision',
          d3.forceCollide().radius((d) => d.size + 4),
        );

      const link = svg
        .append('g')
        .selectAll('line')
        .data(edges)
        .join('line')
        .attr('stroke', '#d1d5db')
        .attr('stroke-width', 1)
        .attr('stroke-opacity', 0.5);

      const node = svg
        .append('g')
        .selectAll('circle')
        .data(nodes)
        .join('circle')
        .attr('r', (d) => d.size)
        .attr('fill', (d) => d.color)
        .attr('fill-opacity', 0.85)
        .attr('stroke', '#fff')
        .attr('stroke-width', 1.5);

      const label = svg
        .append('g')
        .selectAll('text')
        .data(nodes)
        .join('text')
        .text((d) => d.name)
        .attr('text-anchor', 'middle')
        .attr('dy', (d) => d.size + 14)
        .attr('font-size', (d) => (d.group === 'core' ? '11px' : '9px'))
        .attr('font-weight', (d) => (d.group === 'core' ? '700' : '500'))
        .attr('fill', '#374151')
        .attr('pointer-events', 'none');

      simulation.on('tick', () => {
        link
          .attr('x1', (d) => d.source.x)
          .attr('y1', (d) => d.source.y)
          .attr('x2', (d) => d.target.x)
          .attr('y2', (d) => d.target.y);
        node.attr('cx', (d) => d.x).attr('cy', (d) => d.y);
        label.attr('x', (d) => d.x).attr('y', (d) => d.y);
      });
    }
  });
</script>

<style>
  /* ===== SKIP LINK FOR ACCESSIBILITY ===== */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 6px;
    background: #1a1a2e;
    color: white;
    padding: 8px 16px;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    z-index: 100;
    transition: top 0.3s ease;
  }

  .skip-link:focus {
    top: 6px;
  }

  /* ===== SECTION TITLE ===== */
  .section-title {
    font-family:
      'jf-lanyangming', 'Noto Serif TC', 'Source Han Serif TC', serif;
    font-size: 2rem;
    font-weight: 300;
    color: #1f2937;
    text-align: center;
  }

  /* ===== MINI GRAPH SECTION (ZH-only) ===== */
  .mini-graph-section {
    max-width: 800px;
    margin: 0 auto 4rem;
    padding: 0 2rem;
  }

  .mini-graph-link {
    display: block;
    text-decoration: none;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 2rem;
    transition: all 0.3s ease;
  }

  .mini-graph-link:hover {
    border-color: #2d5016;
    box-shadow: 0 4px 12px rgba(45, 80, 22, 0.1);
  }

  .mini-graph-text {
    text-align: center;
    margin-bottom: 1rem;
  }

  .mini-graph-text h3 {
    font-size: 1.3rem;
    color: #1f2937;
    margin-bottom: 0.5rem;
  }

  .mini-graph-text p {
    font-size: 0.95rem;
    color: #6b7280;
  }

  .mini-graph-container {
    width: 100%;
    height: 300px;
    overflow: hidden;
  }

  /* ===== FEATURES CTA (ZH-only slot content) ===== */
  .features-cta {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
    padding: 0 1rem;
  }

  .feature-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    background: #f0fdf4;
    border: 1.5px solid rgba(45, 80, 22, 0.2);
    border-radius: 8px;
    color: #2d5016;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.25s ease;
  }

  .feature-btn:hover {
    background: rgba(45, 80, 22, 0.1);
    border-color: rgba(45, 80, 22, 0.4);
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(45, 80, 22, 0.15);
  }

  .feature-btn.secondary {
    background: #f8fafc;
    border-color: #d1d5db;
    color: #374151;
  }

  .feature-btn.secondary:hover {
    background: #f1f5f9;
    border-color: #9ca3af;
  }

  @media (max-width: 480px) {
    .features-cta {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
