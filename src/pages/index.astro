---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import CoverStory from '../components/home/CoverStory.astro';
import RandomDiscovery from '../components/home/RandomDiscovery.astro';
import ReadingPath from '../components/ReadingPath.astro';
import FeatureCards from '../components/FeatureCards.astro';
import CategoriesSection from '../components/home/CategoriesSection.astro';
import RecentUpdates from '../components/home/RecentUpdates.astro';
import ContributeSection from '../components/home/ContributeSection.astro';
import { fetchRecentCommits } from '../lib/commits';

const recentCommits = await fetchRecentCommits();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const readingPathSteps = [
  {
    href: `${base}/agri-basics/土壤基礎知識`,
    title: '🌱 土壤基礎知識',
    description: '認識嘉義地區土壤特性，新農入門第一步',
    time: '5 min',
  },
  {
    href: `${base}/crop-production/小番茄栽培技術`,
    title: '🌿 小番茄栽培技術',
    description: '從選種到採收，嘉義小番茄完整栽培指南',
    time: '6 min',
  },
  {
    href: `${base}/smart-farming/農業物聯網入門`,
    title: '🤖 農業物聯網入門',
    description: '感測器、數據分析，智慧農業起步走',
    time: '5 min',
  },
  {
    href: `${base}/farm-management/農場財務規劃`,
    title: '🏡 農場財務規劃',
    description: '小農也需要的財務管理基本功',
    time: '5 min',
  },
  {
    href: `${base}/grants-planning/農業補助申請指南`,
    title: '📝 農業補助申請指南',
    description: '補助計畫申請流程與撰寫技巧',
    time: '4 min',
  },
];

const readingPathFooterItems = [
  { icon: '⏱️', label: '總計 25 分鐘' },
  { icon: '🎯', label: '跨越 5 大領域' },
  { icon: '🌟', label: '農業入門起步' },
];
---

<Layout
  title="嘉義國本學堂 — 開源農業知識平台"
  description="嘉義縣國本學堂課程精華，涵蓋農業基礎、作物生產、智慧農業等 10 大主題，互動知識圖譜、開放社群協作。"
>
  <HeroSection />

  <CoverStory />

  <RandomDiscovery />

  <ReadingPath
    title="📖 不知道從哪開始？"
    subtitle="用這 5 篇文章，在 25 分鐘內快速入門農業知識"
    steps={readingPathSteps}
    footerItems={readingPathFooterItems}
    continueHref="#categories"
    continueLabel="繼續探索更多主題 →"
  />

  <FeatureCards
    lang="zh-TW"
    sectionTitle="為什麼需要嘉義國本學堂？"
    cards={[
      {
        icon: '🎯',
        title: '國本學堂精華',
        description: '嘉義縣政府農業處歷屆課程內容，系統化整理',
      },
      {
        icon: '🕸️',
        title: '互動知識圖譜',
        description: '用 D3.js 視覺化農業知識間的關聯與脈絡',
      },
      {
        icon: '🌾',
        title: '在地農業實務',
        description: '嘉義地區作物、設施、智農實戰經驗',
      },
      {
        icon: '📖',
        title: '開源共創',
        description: '任何人都可以貢獻，讓農業知識持續成長',
      },
    ]}
  >
    <div class="features-cta">
      <a href={`${base}/graph`} class="feature-btn">🔗 知識圖譜 — 探索文章之間的連結</a>
      <a
        href="https://github.com/ahnchen1983/agrischlchiayi/tree/main/knowledge"
        target="_blank"
        rel="noopener noreferrer"
        class="feature-btn secondary">📂 瀏覽原始資料 ↗</a
      >
    </div>
  </FeatureCards>

  <section class="mini-graph-section">
    <a href={`${base}/graph`} class="mini-graph-link">
      <div class="mini-graph-text">
        <h3>🕸️ 知識圖譜</h3>
        <p>每篇文章都不是孤島——點擊探索農業知識的連結網絡</p>
      </div>
      <div id="mini-graph" class="mini-graph-container"></div>
    </a>
  </section>

  <CategoriesSection>
    <Fragment slot="prose">
      <p>
        嘉義，北回歸線穿越的農業重鎮。從嘉南平原的稻浪到阿里山的茶園，
        這裡是台灣農業的核心產區之一。
        <a href={`${base}/agri-basics`} class="topic-pill">🌱 農業基礎入門</
        >帶你認識土壤、水資源與有機農法的第一步。
      </p>

      <p>
        國本學堂自創辦以來，培育了數百位新農與返鄉青農。
        從<a href={`${base}/agri-advanced`} class="topic-pill">🌾 進階實務</
        >的田間管理技巧，到<a href={`${base}/crop-production`} class="topic-pill"
          >🌿 作物生產</a
        >的小番茄、百香果栽培指南，每一堂課都是來自產地的實戰經驗。
      </p>

      <p>
        現代農業不只是種田。<a href={`${base}/smart-farming`} class="topic-pill"
          >🤖 智慧農業</a
        >帶來物聯網感測、智慧灌溉與無人機應用；
        <a href={`${base}/facility-farming`} class="topic-pill">🏗️ 設施農業</
        >讓溫室環控成為可能。科技正在改變嘉義的農田風景。
      </p>

      <p>
        經營一座農場需要的不只是農藝。
        <a href={`${base}/farm-management`} class="topic-pill">🏡 農場經營管理</
        >教你財務規劃與人力管理；
        <a href={`${base}/grants-planning`} class="topic-pill">📝 計畫撰寫補助</
        >幫你掌握補助申請的眉角。
      </p>

      <p>
        從產地到餐桌的最後一哩路——<a
          href={`${base}/agri-marketing`}
          class="topic-pill">📦 農產品銷售</
        >探索品牌建立與通路經營。
        而<a href={`${base}/field-visits`} class="topic-pill">🚜 場域交流觀摩</
        >帶你走訪模範農場，看見不同經營模式的可能。
      </p>

      <p>
        <a href={`${base}/livestock-health`} class="topic-pill">🐄 畜牧健康</
        >不可忽視——家禽飼養管理與動物福利同樣是農業的一環。
        所有知識在這裡匯聚，等你探索。
      </p>
    </Fragment>
  </CategoriesSection>

  <RecentUpdates commits={recentCommits} />

  <ContributeSection />
</Layout>

<script is:inline src="https://d3js.org/d3.v7.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    const container = document.getElementById('mini-graph');
    if (container) {
      const categories = [
        { id: 'agri-basics', name: '農業基礎', color: '#22c55e' },
        { id: 'agri-advanced', name: '進階實務', color: '#16a34a' },
        { id: 'farm-management', name: '農場經營', color: '#ca8a04' },
        { id: 'crop-production', name: '作物生產', color: '#15803d' },
        { id: 'facility-farming', name: '設施農業', color: '#0891b2' },
        { id: 'smart-farming', name: '智慧農業', color: '#2563eb' },
        { id: 'agri-marketing', name: '農產銷售', color: '#ea580c' },
        { id: 'grants-planning', name: '計畫補助', color: '#7c3aed' },
        { id: 'field-visits', name: '場域觀摩', color: '#b45309' },
        { id: 'livestock-health', name: '畜牧健康', color: '#dc2626' },
      ];

      const nodes = [
        {
          id: 'chiayi-agri',
          name: '嘉義國本學堂',
          size: 18,
          color: '#2d5016',
          group: 'core',
        },
        ...categories.map((c) => ({
          id: c.id,
          name: c.name,
          size: 12,
          color: c.color,
          group: 'category',
        })),
      ];

      const edges = categories.map((c) => ({ source: 'chiayi-agri', target: c.id }));
      const crossLinks = [
        ['agri-basics', 'agri-advanced'],
        ['agri-basics', 'crop-production'],
        ['farm-management', 'agri-marketing'],
        ['farm-management', 'grants-planning'],
        ['crop-production', 'facility-farming'],
        ['smart-farming', 'facility-farming'],
        ['agri-marketing', 'field-visits'],
        ['livestock-health', 'agri-advanced'],
        ['grants-planning', 'field-visits'],
        ['smart-farming', 'crop-production'],
      ];
      crossLinks.forEach(([source, target]) => edges.push({ source, target }));

      const width = container.clientWidth;
      const height = 300;

      const svg = d3
        .select('#mini-graph')
        .append('svg')
        .attr('viewBox', `0 0 ${width} ${height}`)
        .attr('preserveAspectRatio', 'xMidYMid meet');

      const simulation = d3
        .forceSimulation(nodes)
        .force(
          'link',
          d3
            .forceLink(edges)
            .id((d) => d.id)
            .distance(60),
        )
        .force('charge', d3.forceManyBody().strength(-120))
        .force('center', d3.forceCenter(width / 2, height / 2))
        .force(
          'collision',
          d3.forceCollide().radius((d) => d.size + 4),
        );

      const link = svg
        .append('g')
        .selectAll('line')
        .data(edges)
        .join('line')
        .attr('stroke', '#d1d5db')
        .attr('stroke-width', 1)
        .attr('stroke-opacity', 0.5);

      const node = svg
        .append('g')
        .selectAll('circle')
        .data(nodes)
        .join('circle')
        .attr('r', (d) => d.size)
        .attr('fill', (d) => d.color)
        .attr('fill-opacity', 0.85)
        .attr('stroke', '#fff')
        .attr('stroke-width', 1.5);

      const label = svg
        .append('g')
        .selectAll('text')
        .data(nodes)
        .join('text')
        .text((d) => d.name)
        .attr('text-anchor', 'middle')
        .attr('dy', (d) => d.size + 14)
        .attr('font-size', (d) => (d.group === 'core' ? '11px' : '9px'))
        .attr('font-weight', (d) => (d.group === 'core' ? '700' : '500'))
        .attr('fill', '#374151')
        .attr('pointer-events', 'none');

      simulation.on('tick', () => {
        link
          .attr('x1', (d) => d.source.x)
          .attr('y1', (d) => d.source.y)
          .attr('x2', (d) => d.target.x)
          .attr('y2', (d) => d.target.y);
        node.attr('cx', (d) => d.x).attr('cy', (d) => d.y);
        label.attr('x', (d) => d.x).attr('y', (d) => d.y);
      });
    }
  });
</script>

<style>
  /* ===== SKIP LINK FOR ACCESSIBILITY ===== */
  .skip-link {
    position: absolute;
    top: -40px;
    left: 6px;
    background: #1a1a2e;
    color: white;
    padding: 8px 16px;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    z-index: 100;
    transition: top 0.3s ease;
  }

  .skip-link:focus {
    top: 6px;
  }

  /* ===== SECTION TITLE ===== */
  .section-title {
    font-family:
      'jf-lanyangming', 'Noto Serif TC', 'Source Han Serif TC', serif;
    font-size: 2rem;
    font-weight: 300;
    color: #1f2937;
    text-align: center;
  }

  /* ===== MINI GRAPH SECTION (ZH-only) ===== */
  .mini-graph-section {
    max-width: 800px;
    margin: 0 auto 4rem;
    padding: 0 2rem;
  }

  .mini-graph-link {
    display: block;
    text-decoration: none;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    padding: 2rem;
    transition: all 0.3s ease;
  }

  .mini-graph-link:hover {
    border-color: #2d5016;
    box-shadow: 0 4px 12px rgba(45, 80, 22, 0.1);
  }

  .mini-graph-text {
    text-align: center;
    margin-bottom: 1rem;
  }

  .mini-graph-text h3 {
    font-size: 1.3rem;
    color: #1f2937;
    margin-bottom: 0.5rem;
  }

  .mini-graph-text p {
    font-size: 0.95rem;
    color: #6b7280;
  }

  .mini-graph-container {
    width: 100%;
    height: 300px;
    overflow: hidden;
  }

  /* ===== FEATURES CTA (ZH-only slot content) ===== */
  .features-cta {
    display: flex;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
    padding: 0 1rem;
  }

  .feature-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.5rem;
    background: #f0fdf4;
    border: 1.5px solid rgba(45, 80, 22, 0.2);
    border-radius: 8px;
    color: #2d5016;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    transition: all 0.25s ease;
  }

  .feature-btn:hover {
    background: rgba(45, 80, 22, 0.1);
    border-color: rgba(45, 80, 22, 0.4);
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(45, 80, 22, 0.15);
  }

  .feature-btn.secondary {
    background: #f8fafc;
    border-color: #d1d5db;
    color: #374151;
  }

  .feature-btn.secondary:hover {
    background: #f1f5f9;
    border-color: #9ca3af;
  }

  @media (max-width: 480px) {
    .features-cta {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
