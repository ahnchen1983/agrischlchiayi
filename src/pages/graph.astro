---
import Layout from '../layouts/Layout.astro';
import { readdir, readFile } from 'fs/promises';
import { resolve, join } from 'path';

const categories = [
  'agri-basics',
  'agri-advanced',
  'farm-management',
  'crop-production',
  'facility-farming',
  'smart-farming',
  'agri-marketing',
  'grants-planning',
  'field-visits',
  'livestock-health',
];

const categoryColors: Record<string, string> = {
  'agri-basics': '#4caf50',
  'agri-advanced': '#ff9800',
  'farm-management': '#795548',
  'crop-production': '#8bc34a',
  'facility-farming': '#607d8b',
  'smart-farming': '#2196f3',
  'agri-marketing': '#ff5722',
  'grants-planning': '#9c27b0',
  'field-visits': '#e91e63',
  'livestock-health': '#00bcd4',
};

const categoryNames: Record<string, string> = {
  'agri-basics': '🌱 農業基礎入門',
  'agri-advanced': '🌾 農業進階實務',
  'farm-management': '🏡 農場經營管理',
  'crop-production': '🌿 作物生產技術',
  'facility-farming': '🏗️ 設施農業',
  'smart-farming': '🤖 智慧農業',
  'agri-marketing': '📦 農產品銷售',
  'grants-planning': '📝 計畫撰寫補助',
  'field-visits': '🚜 場域交流觀摩',
  'livestock-health': '🐄 畜牧健康',
};

// Build nodes and edges
const nodes: any[] = [];
const edges: any[] = [];
const tagMap: Record<string, string[]> = {}; // tag → article ids

// Scan filesystem for article data used by the graph view
const allZhArticles: any[] = [];

try {
  for (const cat of categories) {
    const catDir = resolve('src/content/zh-TW', cat);
    try {
      const files = await readdir(catDir);
      for (const file of files) {
        if (file.endsWith('.md') && !file.startsWith('_')) {
          const slug = file.replace(/\.md$/, '');
          const content = await readFile(join(catDir, file), 'utf-8');
          const titleMatch = content.match(/^title:\s*["']?(.+?)["']?\s*$/m);
          const tagsMatch = content.match(/^tags:\s*\[(.+?)\]/m);
          const subcatMatch = content.match(
            /^subcategory:\s*["']?(.+?)["']?\s*$/m,
          );
          const cropMatch = content.match(/^crop:\s*\[(.+?)\]/m);
          const techMatch = content.match(/^tech:\s*\[(.+?)\]/m);
          const title = titleMatch ? titleMatch[1] : slug;
          const tags = tagsMatch
            ? tagsMatch[1].split(',').map((t) => t.trim().replace(/["']/g, ''))
            : [];
          const subcategory = subcatMatch ? subcatMatch[1] : '';
          const crop = cropMatch
            ? cropMatch[1].split(',').map((c) => c.trim().replace(/["']/g, ''))
            : [];
          const tech = techMatch
            ? techMatch[1].split(',').map((t) => t.trim().replace(/["']/g, ''))
            : [];
          allZhArticles.push({
            id: `${cat}/${slug}`,
            data: { title, tags, subcategory, crop, tech },
          });
        }
      }
    } catch {}
  }
} catch {}
// Center node
nodes.push({
  id: 'chiayi-agri',
  label: '嘉義國本學堂',
  group: 'center',
  size: 30,
});

// Special nodes
nodes.push({
  id: 'about',
  label: '📖 關於',
  group: 'special',
  color: '#6366f1',
  size: 14,
  url: '/about',
});
nodes.push({
  id: 'contribute',
  label: '✋ 貢獻',
  group: 'special',
  color: '#22c55e',
  size: 14,
  url: '/contribute',
});
edges.push({ source: 'chiayi-agri', target: 'about' });
edges.push({ source: 'chiayi-agri', target: 'contribute' });

for (const cat of categories) {
  // Chinese article nodes (filter from pre-fetched collection)
  const catArticles = allZhArticles.filter((a) => {
    const parts = a.id.split('/');
    return parts[0] === cat && !parts[parts.length - 1].startsWith('_');
  });

  // Category node
  nodes.push({
    id: cat,
    label: categoryNames[cat] || cat,
    group: cat,
    color: categoryColors[cat],
    size: 20,
    url: `/${cat}`,
  });
  edges.push({ source: 'chiayi-agri', target: cat });

  // Track subcategories for this category
  const subcatSet = new Set<string>();

  for (const article of catArticles) {
    const slug = article.id.split('/').slice(1).join('/').replace(/\.md$/, '');
    const nodeId = `${cat}/${slug}`;
    const subcat = article.data.subcategory || '';

    nodes.push({
      id: nodeId,
      label: article.data.title,
      group: cat,
      color: categoryColors[cat],
      size: 8,
      url: `/${cat}/${encodeURIComponent(slug)}`,
    });

    if (subcat) {
      // Create subcategory virtual node if not exists
      const subcatId = `${cat}/__sub__${subcat}`;
      if (!subcatSet.has(subcat)) {
        subcatSet.add(subcat);
        nodes.push({
          id: subcatId,
          label: subcat,
          group: cat,
          color: categoryColors[cat],
          size: 5,
          isSubcategory: true,
        });
        edges.push({ source: cat, target: subcatId });
      }
      // Article → subcategory
      edges.push({ source: subcatId, target: nodeId });
    } else {
      // No subcategory → connect directly to category
      edges.push({ source: cat, target: nodeId });
    }

    // Build tag connections
    if (article.data.tags) {
      for (const tag of article.data.tags) {
        if (!tagMap[tag]) tagMap[tag] = [];
        tagMap[tag].push(nodeId);
      }
    }
  }
}

// Cross-category edges via shared tags (max 3 per tag to limit O(n²) explosion)
for (const [tag, articleIds] of Object.entries(tagMap)) {
  if (articleIds.length >= 2) {
    let count = 0;
    for (let i = 0; i < articleIds.length - 1 && count < 3; i++) {
      for (let j = i + 1; j < articleIds.length && count < 3; j++) {
        const catA = articleIds[i].split('/')[0];
        const catB = articleIds[j].split('/')[0];
        if (catA !== catB) {
          edges.push({ source: articleIds[i], target: articleIds[j] });
          count++;
        }
      }
    }
  }
}

// Cross-category edges via shared crop/tech fields (max 3 per value)
const cropMap: Record<string, string[]> = {};
const techMap: Record<string, string[]> = {};
for (const article of allZhArticles) {
  const cat = article.id.split('/')[0];
  const slug = article.id.split('/').slice(1).join('/').replace(/\.md$/, '');
  const nodeId = `${cat}/${slug}`;
  const crops = article.data.crop || [];
  const techs = article.data.tech || [];
  for (const c of crops) {
    if (!cropMap[c]) cropMap[c] = [];
    cropMap[c].push(nodeId);
  }
  for (const t of techs) {
    if (!techMap[t]) techMap[t] = [];
    techMap[t].push(nodeId);
  }
}
for (const map of [cropMap, techMap]) {
  for (const [, ids] of Object.entries(map)) {
    if (ids.length >= 2) {
      let count = 0;
      for (let i = 0; i < ids.length - 1 && count < 3; i++) {
        for (let j = i + 1; j < ids.length && count < 3; j++) {
          const catA = ids[i].split('/')[0];
          const catB = ids[j].split('/')[0];
          if (catA !== catB) {
            edges.push({ source: ids[i], target: ids[j] });
            count++;
          }
        }
      }
    }
  }
}

// Parse Hub wikilinks to create Hub→article edges
const categoryMapping: Record<string, string> = {
  'agri-basics': 'Agri-Basics',
  'agri-advanced': 'Agri-Advanced',
  'farm-management': 'Farm-Management',
  'crop-production': 'Crop-Production',
  'facility-farming': 'Facility-Farming',
  'smart-farming': 'Smart-Farming',
  'agri-marketing': 'Agri-Marketing',
  'grants-planning': 'Grants-Planning',
  'field-visits': 'Field-Visits',
  'livestock-health': 'Livestock-Health',
  'crop-index': 'Crop-Index',
  'tech-index': 'Tech-Index',
  'learning-paths': 'Learning-Paths',
};
const nodeIds = new Set(nodes.map((n) => n.id));

for (const [cat, folder] of Object.entries(categoryMapping)) {
  if (!nodeIds.has(cat)) continue; // skip index categories without nodes
  try {
    const hubDir = resolve(process.cwd(), 'knowledge', folder);
    const files = await readdir(hubDir);
    const hubFile = files.find((f) => f.startsWith('_') && f.includes('Hub'));
    if (hubFile) {
      const content = await readFile(join(hubDir, hubFile), 'utf-8');
      // Extract [[wikilink]] references
      const wikilinks =
        content.match(/\[\[([^\]|]+?)(?:\|[^\]]+?)?\]\]/g) || [];
      for (const wl of wikilinks) {
        const target = wl
          .replace(/\[\[/, '')
          .replace(/\]\]/, '')
          .split('|')[0]
          .trim();
        // Check if target matches an article node
        const matchNode = nodes.find(
          (n) =>
            n.label === target ||
            n.label === `🌐 ${target}` ||
            n.id === `${cat}/${target}` ||
            n.id === `${cat}/${encodeURIComponent(target)}`,
        );
        if (matchNode && matchNode.id !== cat) {
          // Avoid duplicate edges
          const exists = edges.some(
            (e) =>
              (e.source === cat && e.target === matchNode.id) ||
              (e.source === matchNode.id && e.target === cat),
          );
          if (!exists) {
            edges.push({ source: cat, target: matchNode.id });
          }
        }
        // Cross-category Hub links (e.g. History Hub mentions [[茶文化]])
        if (!matchNode) {
          for (const [otherCat] of Object.entries(categoryMapping)) {
            if (otherCat === cat) continue;
            const crossNode = nodes.find(
              (n) => n.label === target && n.group === otherCat,
            );
            if (crossNode) {
              edges.push({ source: cat, target: crossNode.id });
              break;
            }
          }
        }
      }
    }
  } catch {}
}

const graphData = JSON.stringify({ nodes, edges });
const basePath = import.meta.env.BASE_URL;
---

<Layout title="🕸️ 知識圖譜 — 嘉義國本學堂">
  <main class="graph-page">
    <div class="graph-header">
      <h1>🕸️ 知識圖譜 Knowledge Graph</h1>
      <p>嘉義國本學堂的所有知識節點與連結</p>
      <div class="search-box">
        <input
          id="graph-search"
          type="search"
          placeholder="搜尋節點或文章"
          aria-label="搜尋知識圖譜節點"
        />
        <span id="search-count" class="search-count"></span>
      </div>
    </div>
    <div id="graph-container"></div>
    <div id="tooltip" class="tooltip"></div>
  </main>
</Layout>

<script define:vars={{ graphData, basePath }}>
  const data = JSON.parse(graphData);

  const script = document.createElement('script');
  script.src = 'https://d3js.org/d3.v7.min.js';
  script.onload = () => initGraph(data);
  document.head.appendChild(script);

  function initGraph(data) {
    const container = document.getElementById('graph-container');
    const width = container.clientWidth;
    const height = container.clientHeight;
    const isCompact = width < 768;

    const svg = d3
      .select('#graph-container')
      .append('svg')
      .attr('width', width)
      .attr('height', height);

    const g = svg.append('g');

    // Zoom
    const zoomBehavior = d3.zoom().on('zoom', (event) => {
      g.attr('transform', event.transform);
    });
    svg.call(zoomBehavior);

    function zoomToFit() {
      const bounds = g.node().getBBox();
      const midX = bounds.x + bounds.width / 2;
      const midY = bounds.y + bounds.height / 2;
      const scale =
        0.85 / Math.max(bounds.width / width, bounds.height / height);
      svg
        .transition()
        .duration(750)
        .call(
          zoomBehavior.transform,
          d3.zoomIdentity
            .translate(width / 2 - scale * midX, height / 2 - scale * midY)
            .scale(scale),
        );
    }

    // Fix center node
    const centerNode = data.nodes.find((n) => n.id === 'chiayi-agri');
    if (centerNode) {
      centerNode.fx = width / 2;
      centerNode.fy = height / 2;
    }

    const simulation = d3
      .forceSimulation(data.nodes)
      .force(
        'link',
        d3
          .forceLink(data.edges)
          .id((d) => d.id)
          .distance((d) => {
            if (d.source.id === 'chiayi-agri' || d.target.id === 'chiayi-agri')
              return 400;
            // Subcategory ↔ article: tight
            if (d.source.isSubcategory || d.target.isSubcategory) return 35;
            // Same group: medium
            if (
              d.source.group &&
              d.target.group &&
              d.source.group === d.target.group
            )
              return 50;
            // Cross-category (crop/tech links)
            return 180;
          })
          .strength(1),
      )
      .force('charge', d3.forceManyBody().strength(-80))
      .force('center', d3.forceCenter(width / 2, height / 2))
      .force(
        'collision',
        d3.forceCollide().radius((d) => d.size + 3),
      );

    // Links
    const link = g
      .append('g')
      .selectAll('line')
      .data(data.edges)
      .join('line')
      .attr('stroke', '#ddd')
      .attr('stroke-width', 1)
      .attr('stroke-opacity', 0.5);

    // Nodes
    const node = g
      .append('g')
      .selectAll('circle')
      .data(data.nodes)
      .join('circle')
      .attr('r', (d) => d.size)
      .attr('fill', (d) => {
        if (d.group === 'center') return '#1a1a2e';
        if (d.isSubcategory) return d.color + 'cc'; // slightly transparent
        return d.color || '#ccc';
      })
      .attr('stroke', (d) => (d.isSubcategory ? d.color : '#fff'))
      .attr('stroke-width', (d) => (d.isSubcategory ? 1.5 : 2))
      .attr('cursor', 'pointer')
      .call(
        d3
          .drag()
          .on('start', (event, d) => {
            if (!event.active) simulation.alphaTarget(0.3).restart();
            d.fx = d.x;
            d.fy = d.y;
          })
          .on('drag', (event, d) => {
            d.fx = event.x;
            d.fy = event.y;
          })
          .on('end', (event, d) => {
            if (!event.active) simulation.alphaTarget(0);
            if (d.id !== 'chiayi-agri') {
              d.fx = null;
              d.fy = null;
            }
          }),
      );

    // Labels
    const label = g
      .append('g')
      .selectAll('text')
      .data(data.nodes)
      .join('text')
      .text((d) => d.label)
      .attr('font-size', (d) => {
        if (d.group === 'center') return isCompact ? '14px' : '16px';
        if (d.size >= 20) return isCompact ? '12px' : '13px';
        if (d.isSubcategory) return isCompact ? '7px' : '8px';
        return isCompact ? '9px' : '9px';
      })
      .attr('font-weight', (d) => (d.size >= 14 ? 'bold' : 'normal'))
      .attr('text-anchor', 'middle')
      .attr('dy', (d) => d.size + 14)
      .attr('fill', '#333')
      .attr('filter', 'drop-shadow(0 1px 2px rgba(255,255,255,0.8))')
      .attr('pointer-events', 'none');

    // Click
    node.on('click', (event, d) => {
      if (d.url) window.location.href = basePath.replace(/\/$/, '') + d.url;
    });

    // Hover
    const tooltip = document.getElementById('tooltip');
    node
      .on('mouseover', (event, d) => {
        tooltip.textContent = d.label;
        tooltip.style.display = 'block';
        tooltip.style.left = event.pageX + 10 + 'px';
        tooltip.style.top = event.pageY - 10 + 'px';
        d3.select(event.target)
          .attr('stroke', '#3b82f6')
          .attr('stroke-width', 3);
      })
      .on('mouseout', (event, d) => {
        tooltip.style.display = 'none';
        d3.select(event.target)
          .attr('stroke', d.isSubcategory ? d.color : '#fff')
          .attr('stroke-width', d.isSubcategory ? 1.5 : 2);
      });

    // Search
    const searchInput = document.getElementById('graph-search');
    const searchCount = document.getElementById('search-count');

    function applySearch(query) {
      const normalized = query.trim().toLowerCase();
      if (!normalized) {
        node
          .attr('opacity', 1)
          .attr('stroke', (d) => (d.isSubcategory ? d.color : '#fff'))
          .attr('stroke-width', (d) => (d.isSubcategory ? 1.5 : 2));
        link.attr('opacity', 0.5);
        label.attr('opacity', 1);
        if (searchCount) searchCount.textContent = '';
        return;
      }

      const matchedIds = new Set(
        data.nodes
          .filter((n) =>
            String(n.label || '')
              .toLowerCase()
              .includes(normalized),
          )
          .map((n) => n.id),
      );

      node
        .attr('opacity', (d) => (matchedIds.has(d.id) ? 1 : 0.12))
        .attr('stroke', (d) => (matchedIds.has(d.id) ? '#3b82f6' : '#fff'))
        .attr('stroke-width', (d) => (matchedIds.has(d.id) ? 3 : 2));
      label.attr('opacity', (d) => (matchedIds.has(d.id) ? 1 : 0.15));
      link.attr('opacity', (d) => {
        const s = typeof d.source === 'object' ? d.source.id : d.source;
        const t = typeof d.target === 'object' ? d.target.id : d.target;
        return matchedIds.has(s) || matchedIds.has(t) ? 0.75 : 0.06;
      });

      if (searchCount) {
        searchCount.textContent =
          matchedIds.size > 0 ? `${matchedIds.size} 個結果` : '無結果';
      }
    }

    if (searchInput) {
      searchInput.addEventListener('input', (event) =>
        applySearch(event.target.value),
      );
    }

    let ticked = 0;
    simulation.on('tick', () => {
      link
        .attr('x1', (d) => d.source.x)
        .attr('y1', (d) => d.source.y)
        .attr('x2', (d) => d.target.x)
        .attr('y2', (d) => d.target.y);
      node.attr('cx', (d) => d.x).attr('cy', (d) => d.y);
      label.attr('x', (d) => d.x).attr('y', (d) => d.y);
      ticked++;
      if (ticked === 100) zoomToFit();
    });
  }
</script>

<style>
  .graph-page {
    height: 100vh;
    display: flex;
    flex-direction: column;
  }
  .graph-header {
    padding: 1rem var(--space-page-x);
    background: #1a1a2e;
    color: white;
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .graph-header h1 {
    font-size: clamp(1.25rem, 2.4vw, 1.8rem);
    margin: 0;
    font-family: var(--font-editorial);
    line-height: var(--title-line-height);
    letter-spacing: var(--title-letter-spacing);
    font-weight: 800;
  }
  .graph-header p {
    opacity: 0.78;
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.6;
    max-width: 34rem;
    color: rgba(255, 255, 255, 0.82);
  }
  .search-box {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  #graph-search {
    padding: 0.4rem 0.8rem;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.1);
    color: white;
    font-size: 0.9rem;
    width: 200px;
    outline: none;
    transition:
      border-color 0.2s,
      background 0.2s;
  }
  #graph-search::placeholder {
    color: rgba(255, 255, 255, 0.5);
  }
  #graph-search:focus {
    border-color: #3b82f6;
    background: rgba(255, 255, 255, 0.15);
  }
  .search-count {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.8rem;
    white-space: nowrap;
  }
  #graph-container {
    flex: 1;
    background: #fafafa;
    overflow: hidden;
  }
  .tooltip {
    display: none;
    position: absolute;
    background: rgba(26, 26, 46, 0.9);
    color: white;
    padding: 0.4rem 0.8rem;
    border-radius: 6px;
    font-size: 0.85rem;
    pointer-events: none;
    z-index: 100;
  }
  @media (max-width: 768px) {
    .graph-header {
      align-items: flex-start;
      padding: 0.9rem 1rem;
    }
    .graph-header h1 {
      font-size: 1.12rem;
      line-height: 1.3;
    }
    .graph-header p {
      width: 100%;
      font-size: 0.9rem;
      order: 3;
    }
    .search-box {
      width: 100%;
      order: 4;
      margin-left: 0;
      flex-wrap: wrap;
    }
    #graph-search {
      width: 100%;
    }
  }
</style>
