---
interface Props {
  title: string;
  description?: string;
  image?: string;
  url?: string;
  lang?: 'zh-TW' | 'en';
  type?: 'website' | 'article';
  datePublished?: string;
  dateModified?: string;
  content?: string;
  tags?: string[];
  category?: string;
}

const { lang = 'zh-TW' } = Astro.props;
const {
  title,
  description = lang === 'en'
    ? 'Chiayi Agricultural Academy is an open-source agricultural knowledge platform built from Chiayi County Guoben School materials, covering farming basics, crop production, smart farming, grants, and field visits.'
    : '嘉義國本學堂是以嘉義縣國本學堂與在地農業課程為基礎的開源知識平台，涵蓋農業基礎、作物生產、智慧農業、農場管理、場域交流與補助申請。',
  image = '/images/taiwan-social.jpg',
  url = Astro.url.href,
  type = 'website',
  datePublished,
  dateModified,
  content,
  tags,
  category,
} = Astro.props;

const siteOrigin = (
  Astro.site?.href || 'https://ahnchen1983.github.io'
).replace(/\/$/, '');
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
const siteUrl = `${siteOrigin}${basePath}`;
const normalizedImage = /^https?:\/\//.test(image)
  ? image
  : `${basePath}${image.startsWith('/') ? image : `/${image}`}`;
const fullTitle = `${title} | 嘉義國本學堂`;
const fullImageUrl = new URL(normalizedImage, siteOrigin).href;

// Generate AI-friendly summary from description or content
const aiSummary =
  description ||
  (content
    ? content
        .substring(0, 200)
        .replace(/[\n\r]/g, ' ')
        .replace(/[#*]/g, '')
        .trim() + '...'
    : '');

// Generate JSON-LD structured data
const generateJSONLD = () => {
  // Person pages (people category)
  if (category === 'people' || category === 'People') {
    return {
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: title,
      description: description,
      url: url,
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': url,
      },
      ...(datePublished && { birthDate: datePublished }),
    };
  }

  // Article pages
  if (type === 'article' && datePublished) {
    return {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description: description,
      author: {
        '@type': 'Organization',
        name: '嘉義國本學堂',
        url: siteUrl,
      },
      publisher: {
        '@type': 'Organization',
        name: '嘉義國本學堂',
        url: siteUrl,
        logo: {
          '@type': 'ImageObject',
          url: `${siteUrl}/images/taiwan-social.jpg`,
          width: 1200,
          height: 630,
        },
      },
      datePublished: datePublished,
      dateModified: dateModified || datePublished,
      inLanguage: lang,
      url: url,
      image: {
        '@type': 'ImageObject',
        url: fullImageUrl,
        width: 1200,
        height: 630,
      },
      mainEntityOfPage: {
        '@type': 'WebPage',
        '@id': url,
      },
      ...(tags && tags.length > 0 && { keywords: tags.join(', ') }),
      ...(category && { articleSection: category }),
    };
  }

  // Website root
  return {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name:
      lang === 'en'
        ? 'Chiayi Agricultural Academy — Knowledge Platform'
        : '嘉義國本學堂 - 開源農業知識平台',
    description:
      lang === 'en'
        ? 'Open-source agricultural knowledge platform about Chiayi farming, crop production, smart agriculture, field visits, and farm management.'
        : '以嘉義農業課程與在地實務為核心的開源知識平台，整理農業基礎、作物栽培、智慧農業與農場管理。',
    url: siteUrl,
    inLanguage: lang,
    publisher: {
      '@type': 'Organization',
      name: '嘉義國本學堂',
      url: siteUrl,
      logo: {
        '@type': 'ImageObject',
        url: `${siteUrl}/images/taiwan-social.jpg`,
        width: 1200,
        height: 630,
      },
    },
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: `${siteUrl}/search?q={search_term_string}`,
      },
      'query-input': 'required name=search_term_string',
    },
    sameAs: ['https://github.com/ahnchen1983/agrischlchiayi'],
  };
};

const jsonLD = generateJSONLD();

// Organization Schema for all pages
const organizationLD = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: '嘉義國本學堂',
  url: siteUrl,
  logo: `${siteUrl}/images/taiwan-social.jpg`,
  description:
    lang === 'en'
      ? 'Open-source agricultural knowledge platform for Chiayi and Taiwan farming topics'
      : '以嘉義農業課程與在地實務為核心的開源農業知識平台',
  foundingDate: '2026',
  sameAs: ['https://github.com/ahnchen1983/agrischlchiayi'],
  contactPoint: {
    '@type': 'ContactPoint',
    email: 'cheyu.wu@monoame.com',
    contactType: 'Customer Support',
  },
};

// Dynamic keywords
const baseKeywords =
  lang === 'en'
    ? 'Chiayi agriculture, agricultural knowledge base, crop production, smart farming, farm management, grants'
    : '嘉義農業, 農業知識庫, 作物生產, 智慧農業, 農場管理, 農業補助';

const categoryKeywords = category
  ? lang === 'en'
    ? [`Taiwan ${category}`, `${category} Taiwan`]
    : [`台灣${category}`, `${category}台灣`]
  : [];

const dynamicKeywords = [
  baseKeywords,
  ...categoryKeywords,
  ...(tags && tags.length > 0 ? tags : []),
].join(', ');

// BreadcrumbList JSON-LD for content pages
const generateBreadcrumbLD = () => {
  const currentPath = new URL(url).pathname;
  const isEn = lang === 'en';

  // Homepage - no breadcrumb needed
  if (currentPath === '/' || currentPath === '/en' || currentPath === '/en/') {
    return null;
  }

  const baseItems = [
    {
      '@type': 'ListItem',
      position: 1,
      name: '嘉義國本學堂',
      item: isEn ? `${siteUrl}/en` : siteUrl,
    },
  ];

  // Category page (e.g., /history, /en/culture)
  if (
    category &&
    (currentPath.endsWith(`/${category}`) ||
      currentPath.endsWith(`/${category}/`))
  ) {
    return {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        ...baseItems,
        {
          '@type': 'ListItem',
          position: 2,
          name: category,
          item: url,
        },
      ],
    };
  }

  // Article page
  if (category && type === 'article') {
    const categoryUrl = isEn
      ? `${siteUrl}/en/${category}`
      : `${siteUrl}/${category}`;
    return {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: [
        ...baseItems,
        {
          '@type': 'ListItem',
          position: 2,
          name: category,
          item: categoryUrl,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: title,
          item: url,
        },
      ],
    };
  }

  // Other pages (about, contribute, etc.)
  return {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      ...baseItems,
      {
        '@type': 'ListItem',
        position: 2,
        name: title,
        item: url,
      },
    ],
  };
};

const breadcrumbLD = generateBreadcrumbLD();
---

<!-- Basic Meta Tags -->
<meta name="description" content={description} />
<meta name="keywords" content={dynamicKeywords} />
<meta name="author" content="嘉義國本學堂" />
<meta name="generator" content="Astro" />
<meta name="theme-color" content="#004d40" />
<meta name="format-detection" content="telephone=no" />

<!-- Additional SEO Meta Tags -->
<meta name="revisit-after" content="7 days" />
<meta name="distribution" content="global" />
<meta name="rating" content="general" />

<!-- AI-friendly summary meta tag -->
<meta name="ai-summary" content={aiSummary} />

<!-- Canonical URL -->
<link rel="canonical" href={url} />

<!-- RSS Feed -->
<link
  rel="alternate"
  type="application/rss+xml"
  title={lang === 'en'
    ? 'Chiayi Agricultural Academy RSS Feed'
    : '嘉義國本學堂 RSS 動態消息'}
  href={`${siteUrl}/feed.xml`}
/>

<!-- Preconnect to external resources -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<!-- DNS prefetch -->
<link rel="dns-prefetch" href="//github.com" />
<link rel="dns-prefetch" href="//x.com" />

<!-- Dynamic Language Tags -->
{
  (() => {
    const currentPath = new URL(url).pathname;
    const routePath =
      basePath && currentPath.startsWith(basePath)
        ? currentPath.slice(basePath.length) || '/'
        : currentPath;
    let zhHref = siteUrl;
    let enHref = `${siteUrl}/en`;

    // For specific pages, build proper hreflang URLs
    if (routePath !== '/' && routePath !== '/en' && routePath !== '/en/') {
      if (routePath.startsWith('/en/')) {
        // Current is English, generate Chinese equivalent
        enHref = url;
        const cleanPath = routePath.replace(/^\/en/, '') || '/';
        zhHref = `${siteUrl}${cleanPath}`;
      } else {
        // Current is Chinese, generate English equivalent
        zhHref = url;
        enHref = `${siteUrl}/en${routePath}`;
      }
    }

    return (
      <>
        <link rel="alternate" hreflang="zh-TW" href={zhHref} />
        <link rel="alternate" hreflang="en" href={enHref} />
        <link rel="alternate" hreflang="x-default" href={zhHref} />
      </>
    );
  })()
}

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={url} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={fullImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:type" content="image/jpeg" />
<meta property="og:image:alt" content={`${title} - 嘉義國本學堂`} />
<meta property="og:site_name" content="嘉義國本學堂 — 開源農業知識平台" />
<meta property="og:locale" content={lang === 'zh-TW' ? 'zh_TW' : 'en_US'} />
{
  datePublished && (
    <meta property="article:published_time" content={datePublished} />
  )
}
{
  dateModified && (
    <meta property="article:modified_time" content={dateModified} />
  )
}
{
  tags &&
    tags.map((tag: string) => <meta property="article:tag" content={tag} />)
}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@cheyuwu345" />
<meta name="twitter:creator" content="@cheyuwu345" />
<meta name="twitter:url" content={url} />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={fullImageUrl} />
<meta name="twitter:image:alt" content={`${title} - 嘉義國本學堂`} />

<!-- Additional SEO -->
<meta name="robots" content="index, follow" />
<meta name="googlebot" content="index, follow" />

<!-- JSON-LD Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLD, null, 2)} />
<script
  type="application/ld+json"
  set:html={JSON.stringify(organizationLD, null, 2)}
/>
{
  breadcrumbLD && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify(breadcrumbLD, null, 2)}
    />
  )
}
