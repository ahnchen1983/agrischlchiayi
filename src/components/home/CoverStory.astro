---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const quotes = [
  {
    era: '1624',
    quote: '「嘉南平原，沃野千里，水利之便，為全台之冠。」',
    cite: '— 荷蘭時期文獻，最早記載嘉南平原農業潛力',
  },
  {
    era: '1930',
    quote: '「嘉南大圳通水之日，即嘉南平原重生之時。」',
    cite: '— 八田與一，嘉南大圳完工，灌溉面積達 15 萬甲',
  },
  {
    era: '1953',
    quote: '「耕者有其田，是台灣農村安定的基石。」',
    cite: '— 土地改革時期，奠定台灣小農經濟基礎',
  },
  {
    era: '2005',
    quote: '「阿里山茶不只是飲料，是嘉義山林與人的對話。」',
    cite: '— 嘉義高山茶農，茶園海拔 1,000-1,700 公尺',
  },
  {
    era: '2020',
    quote: '「智慧農業不是取代農人，而是讓農人更自由。」',
    cite: '— 國本學堂智慧農業課程講師',
  },
  {
    era: '現在',
    quote: '「每一堂課，都是一顆種子。我們種的不只是作物，是知識。」',
    cite: '— 嘉義國本學堂，持續耕耘中',
  },
];
---

<section class="cover-story">
  <div class="cover-content">
    <h2>為什麼是嘉義？</h2>
    <p class="cover-lead">
      北回歸線穿越的農業重鎮，嘉南平原的心臟地帶。<br />
      從水稻、小番茄到阿里山茶，嘉義是台灣農業的縮影。
    </p>
    <div class="quotes-timeline">
      {
        quotes.map((q, i) => (
          <div class="quote-era">
            <div class="quote-indicator">
              <div class="quote-dot" />
              {i < quotes.length - 1 && <div class="quote-line" />}
            </div>
            <div class="quote-body">
              <span class="era-label">{q.era}</span>
              <blockquote>
                {q.quote}
                <cite>{q.cite}</cite>
              </blockquote>
            </div>
          </div>
        ))
      }
    </div>
    <div class="cover-closing">
      <p>
        從嘉南大圳灌溉的稻田到無人機巡田的智慧農場，從阿公的經驗到青農的創新。嘉義農業的故事跨越百年，仍在繼續。
      </p>
      <p>
        <strong>嘉義國本學堂不只是課程紀錄。</strong>
        我們想把每一堂課變成一篇知識，讓農業智慧不再只留在教室裡。
      </p>
      <a href={`${base}/about`} class="cover-link">認識嘉義國本學堂 →</a>
    </div>
  </div>
</section>

<style>
  .cover-story {
    padding: 6rem 2rem;
    background: #fafbfc;
  }
  .cover-content {
    max-width: 780px;
    margin: 0 auto;
  }
  .cover-content h2 {
    font-family:
      'jf-lanyangming', 'Noto Serif TC', 'Source Han Serif TC', serif;
    font-size: 2rem;
    color: #1a1a2e;
    margin-bottom: 1rem;
    text-align: center;
    font-weight: 300;
    letter-spacing: 0;
  }
  .cover-lead {
    text-align: center;
    font-family:
      'jf-jinxuanlatte', 'Noto Sans TC', 'Source Han Sans TC', sans-serif;
    font-size: 1.1rem;
    color: #475569;
    line-height: 2;
    margin-bottom: 3rem;
    font-weight: 600;
  }
  .quotes-timeline {
    display: flex;
    flex-direction: column;
  }
  .quote-era {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: 0 1rem;
    margin-bottom: 0;
  }
  .quote-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .quote-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #22c55e;
    border: 2px solid #fff;
    outline: 2px solid #22c55e;
    flex-shrink: 0;
    margin-top: 0.35rem;
  }
  .quote-line {
    width: 2px;
    flex: 1;
    background: linear-gradient(180deg, #22c55e, #e2e8f0);
    margin-top: 4px;
    min-height: 2rem;
  }
  .quote-era:nth-child(even) .quote-dot {
    background: #059669;
    outline-color: #059669;
  }
  .quote-era:nth-child(even) .quote-line {
    background: linear-gradient(180deg, #059669, #e2e8f0);
  }
  .quote-era:last-child .quote-dot {
    background: #f59e0b;
    outline-color: #f59e0b;
  }
  .quote-body {
    padding-bottom: 2rem;
  }
  .era-label {
    display: inline-block;
    font-family:
      'jf-jinxuanlatte', 'Noto Sans TC', 'Source Han Sans TC', sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0;
    color: #16a34a;
    margin-bottom: 0.5rem;
    padding: 0.15rem 0.5rem;
    background: #f0fdf4;
    border-radius: 4px;
  }
  .quote-era:nth-child(even) .era-label {
    color: #059669;
    background: #ecfdf5;
  }
  .quote-era:last-child .era-label {
    color: #b45309;
    background: #fffbeb;
  }
  .quote-era blockquote {
    margin: 0;
    font-family:
      'jf-jinxuanlatte', 'Noto Sans TC', 'Source Han Sans TC', sans-serif;
    font-size: 1.05rem;
    line-height: 1.9;
    color: #1e293b;
    font-style: normal;
    font-weight: 600;
  }
  .quote-era cite {
    display: block;
    font-family:
      'jf-jinxuanlatte', 'Noto Sans TC', 'Source Han Sans TC', sans-serif;
    font-size: 0.8rem;
    color: #94a3b8;
    font-style: normal;
    margin-top: 0.4rem;
  }
  .cover-closing {
    margin-top: 3rem;
    text-align: center;
    font-family:
      'jf-jinxuanlatte', 'Noto Sans TC', 'Source Han Sans TC', sans-serif;
    font-size: 1.05rem;
    line-height: 1.9;
    color: #475569;
  }
  .cover-closing strong {
    color: #1a1a2e;
  }
  .cover-closing p {
    margin-bottom: 1rem;
  }
  .cover-link {
    display: inline-block;
    margin-top: 0.5rem;
    color: #16a34a;
    text-decoration: none;
    font-weight: 500;
  }
  .cover-link:hover {
    text-decoration: underline;
  }
</style>
