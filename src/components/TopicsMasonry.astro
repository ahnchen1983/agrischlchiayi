---
import * as fs from 'node:fs';
import * as path from 'node:path';
import TopicCard from './TopicCard.astro';
import {
  getLangFromUrl,
  useTranslations,
  useTranslatedPath,
} from '../i18n/utils';
import { defaultLang } from '../i18n/ui';
import { getCategoryConfigs } from '../utils/categoryConfig';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);
const base = import.meta.env.BASE_URL;
const toHref = (p: string) => base + translatePath(p).replace(/^\//, '');
const categoryConfigs = getCategoryConfigs();

// Count articles from knowledge/ directory
function countArticles(categorySlug: string): number {
  const categoryMap: Record<string, string> = {
    'agri-basics': 'Agri-Basics',
    'agri-advanced': 'Agri-Advanced',
    'farm-management': 'Farm-Management',
    'crop-production': 'Crop-Production',
    'facility-farming': 'Facility-Farming',
    'smart-farming': 'Smart-Farming',
    'agri-marketing': 'Agri-Marketing',
    'grants-planning': 'Grants-Planning',
    'field-visits': 'Field-Visits',
    'livestock-health': 'Livestock-Health',
    'crop-index': 'Crop-Index',
    'tech-index': 'Tech-Index',
    'learning-paths': 'Learning-Paths',
  };
  const dirName = categoryMap[categorySlug] || categorySlug;
  const langDir = lang === defaultLang ? '' : lang;
  const dirPath = path.join(process.cwd(), 'knowledge', langDir, dirName);
  try {
    const files = fs.readdirSync(dirPath);
    return files.filter((f) => f.endsWith('.md') && !f.startsWith('_')).length;
  } catch {
    return 0;
  }
}

const articleLabel = t('CategoryGrid.articles');
const ctaLabel = t('CategoryGrid.explore');

// Interleaved heights for visual balance across 3 columns
const categories: { slug: string; height: 'tall' | 'medium' | 'short' }[] = [
  { slug: 'agri-basics', height: 'tall' },
  { slug: 'agri-advanced', height: 'medium' },
  { slug: 'farm-management', height: 'tall' },
  { slug: 'crop-production', height: 'short' },
  { slug: 'facility-farming', height: 'medium' },
  { slug: 'smart-farming', height: 'short' },
  { slug: 'agri-marketing', height: 'tall' },
  { slug: 'grants-planning', height: 'medium' },
  { slug: 'field-visits', height: 'tall' },
  { slug: 'livestock-health', height: 'short' },
];
---

<section class="topics-masonry" aria-label={t('CategoryGrid.aria-section')}>
  {
    categories.map(({ slug, height }) => {
      const count = countArticles(slug);
      const cfg = categoryConfigs[slug];
      return (
        <article class="masonry-item">
          <TopicCard
            slug={slug}
            href={toHref(`/${slug}`)}
            name={cfg?.name ?? slug}
            description={cfg?.description ?? ''}
            count={count}
            articleLabel={articleLabel}
            ctaLabel={ctaLabel}
            height={height}
          />
        </article>
      );
    })
  }
</section>

<style>
  .topics-masonry {
    columns: 1;
    column-gap: 3rem;
    max-width: 90rem;
    margin-inline: auto;
    padding-inline: var(--space-page-x, 2rem);
  }

  @media (min-width: 640px) {
    .topics-masonry {
      columns: 2;
    }
  }

  @media (min-width: 1024px) {
    .topics-masonry {
      columns: 3;
    }
  }

  .masonry-item {
    break-inside: avoid;
    margin-bottom: 3rem;
  }
</style>
