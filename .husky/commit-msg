# Patterns are generic descriptions, not names
FILENAME_PATTERNS = re.compile(
    r"VERIFICATION-REPORT-\d+\.\d+|FARMER-DATA-EXECUTION-SCHEDULE|source/[\u4e00-\u9fff]+\.md"
)
CHINESE_RUN = re.compile(r"[\u4e00-\u9fff]+")

