if not sys.stderr.isatty():
    RED = YELLOW = BOLD = RESET = ""

msg = Path(sys.argv[1]).read_text(encoding="utf-8", errors="replace")

def sha16(s: str) -> str:
    return hashlib.sha256(s.encode("utf-8")).hexdigest()[:16]

def find_hash_hits(text: str) -> set[str]:
    hits = set()
    for m in CHINESE_RUN.finditer(text):
        run = m.group(0)
        for size in WINDOW_SIZES:
            for i in range(0, len(run) - size + 1):
                w = run[i:i+size]
                if sha16(w) in SENSITIVE_HASHES:
                    hits.add(w)
    return hits

