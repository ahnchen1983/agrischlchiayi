#!/usr/bin/env bash
# ============================================================
# Commit-message Deidentification Check
# ============================================================
# Blocks commits whose MESSAGE contains sensitive farmer data.
# (The pre-commit hook handles file content; this handles the message.)
#
# Bypass (emergency only): git commit --no-verify
# See DEIDENTIFICATION-POLICY.md
# ============================================================

msg_file="$1"
msg=$(cat "$msg_file")

# Colors
if [ -t 2 ]; then
  RED=$'\033[31m'
  YELLOW=$'\033[33m'
  BOLD=$'\033[1m'
  RESET=$'\033[0m'
else
  RED=""; YELLOW=""; BOLD=""; RESET=""
fi

FARMER_NAMES="Farmer-A|Farmer-B|Farmer-C|Farmer-D|Farmer-E|Farmer-F|Farmer-G|Farmer-H|Farmer-I|Farmer-J|Farmer-L|Farmer-M|Farmer-N|Farmer-O|[某農友真名]"
FARM_NAMES="[Farm-A]|[Farm-A]|[Farm-B]|[Farm-B]"

# Sensitive file references in commit message (e.g. "VERIFICATION-REPORT-2.1", "source/farmer.md")
FILENAME_PATTERNS="VERIFICATION-REPORT-[0-9]+\.[0-9]+|FARMER-DATA-EXECUTION-SCHEDULE|source/[一-龥]+\.md"

violations=0

# Check for farmer names
name_hits=$(echo "$msg" | grep -oE "$FARMER_NAMES" | sort -u || true)
if [ -n "$name_hits" ]; then
  echo "" >&2
  echo "${RED}${BOLD}❌ Commit 訊息含有農友真名：${RESET}" >&2
  echo "$name_hits" | sed "s/^/   ${RED}→${RESET} /" >&2
  violations=$((violations + 1))
fi

# Check for farm names
farm_hits=$(echo "$msg" | grep -oE "$FARM_NAMES" | sort -u || true)
if [ -n "$farm_hits" ]; then
  echo "" >&2
  echo "${RED}${BOLD}❌ Commit 訊息含有農場/企業名稱：${RESET}" >&2
  echo "$farm_hits" | sed "s/^/   ${RED}→${RESET} /" >&2
  violations=$((violations + 1))
fi

# Check for sensitive filename references
file_hits=$(echo "$msg" | grep -oE "$FILENAME_PATTERNS" | sort -u || true)
if [ -n "$file_hits" ]; then
  echo "" >&2
  echo "${RED}${BOLD}❌ Commit 訊息含有敏感檔名：${RESET}" >&2
  echo "$file_hits" | sed "s/^/   ${RED}→${RESET} /" >&2
  echo "   ${YELLOW}改為通用描述（如「internal farmer documentation」）${RESET}" >&2
  violations=$((violations + 1))
fi

if [ "$violations" -gt 0 ]; then
  echo "" >&2
  echo "${RED}${BOLD}═══════════════════════════════════════════════════════════${RESET}" >&2
  echo "${RED}${BOLD}🚨 Commit 訊息被阻擋：發現 $violations 項去識別化違規${RESET}" >&2
  echo "${RED}${BOLD}═══════════════════════════════════════════════════════════${RESET}" >&2
  echo "" >&2
  echo "${BOLD}允許的訊息範例：${RESET}" >&2
  echo "  ${YELLOW}docs: update internal farmer data documentation${RESET}" >&2
  echo "  ${YELLOW}content: add crop cultivation guide with anonymized case studies${RESET}" >&2
  echo "  ${YELLOW}fix: remove sensitive information from data sources${RESET}" >&2
  echo "" >&2
  echo "${BOLD}完整政策：${RESET} DEIDENTIFICATION-POLICY.md" >&2
  echo "" >&2
  exit 1
fi

exit 0
